# Copy this file to .env and fill in the key(s) for the provider you choose.
# config.py auto-loads .env at startup (zero-dependency loader).

# Which foundation model drives the agents. One of: anthropic | openai | gemini
# Anthropic (Claude) is the highest quality but most expensive; openai (gpt-4o-mini)
# and gemini (gemini-2.0-flash) are much cheaper alternatives.
LLM_PROVIDER=anthropic

# Provide the key for whichever provider you selected above.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Optional model overrides (sensible cheap defaults are used if omitted):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.5-flash
